%% Image Horse — whole-app system architecture (target, July 2026)
%% The dashed "Network" plane is optional: sever it and the solid
%% client subgraph is a complete, working editor. Demo mode is sacred.
flowchart TB
    subgraph client["BROWSER — fully functional offline"]
        direction TB

        subgraph ui["UI plane · React 18 + TypeScript + Vite"]
            SHELL["AppShell<br/>composition + layout only"]
            REG["Tool registry<br/>ToolModule x ~10"]
            SESS["Session hooks<br/>image · selection · canvas · mask"]
            STORES["Zustand stores<br/>UI · Tool · Gallery · Annotation · Guides"]
        end

        subgraph compute["Compute plane"]
            ENGINE["WASM engine · stamp_tool<br/>kernels · TileBuffer · OpLog<br/>+ planned: edge core · PatchMatch · seam carve · color-blind sim"]
            CODEC["Codec worker<br/>encode · thumbnail · OffscreenCanvas<br/>+ planned: indexed-color optimizer"]
            RAYON["rayon worker pool — planned<br/>gated on COOP/COEP spike"]
            WGPU["WebGPU backend — far<br/>filter + composite throughput"]
        end

        subgraph persist["Persistence plane · IndexedDB / Dexie"]
            ORIG["originals<br/>content-addressed · immutable"]
            OPS["opLogs + keyframes"]
            GAL["gallery manifest"]
            CACHE["renderCache<br/>disposable"]
        end

        LOCAL["localStorage<br/>lightweight prefs"]
        SW["Service worker<br/>precache shell + WASM"]
    end

    subgraph edge["NETWORK — optional, additive only"]
        direction TB
        CLERK["Clerk<br/>identity"]
        CONVEX["Convex<br/>prefs sync · entitlements · gallery"]
        AIPROXY["AI proxy → Replicate<br/>server holds provider key"]
        SHARE["Share delivery<br/>ShareViewer"]
    end

    %% core editing path
    SHELL --> STORES
    STORES --> REG
    REG -->|ToolContext| ENGINE
    SESS -->|batched pointer events| ENGINE
    ENGINE -->|dirty tiles| SHELL

    %% encode + persist
    SESS -->|pixels transferable| CODEC
    CODEC -->|Blob| CACHE
    SESS --> ORIG
    SESS --> OPS
    SESS --> GAL
    STORES --> LOCAL
    CACHE -.->|invalid → keyframe + replay| ENGINE

    %% offline delivery
    SW -. serves .-> ui
    SW -. serves .-> compute

    %% optional network plane
    ui -. auth .-> CLERK
    STORES -. signed in .-> CONVEX
    OPS -. paid: cloud backup .-> CONVEX
    SESS -. paid: server op .-> AIPROXY
    AIPROXY -. result .-> SESS
    GAL -. free+: create link .-> SHARE

    %% planned compute wiring
    RAYON -. parallel kernels .-> ENGINE
    WGPU -. render backend .-> ENGINE

    classDef optional stroke-dasharray:5 4;
    class edge,CLERK,CONVEX,AIPROXY,SHARE optional;
    classDef planned stroke-dasharray:3 3;
    class RAYON,WGPU planned;

    classDef truth fill:transparent,stroke-width:2px;
    class ORIG,OPS truth;
