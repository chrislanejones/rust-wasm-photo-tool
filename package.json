{
  "name": "rust-wasm-photo-tool",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "pnpm --filter stamp-tool dev",
    "dev:marketing": "pnpm --filter photo-horse-marketing dev",
    "build": "pnpm --filter stamp-tool build",
    "build:marketing": "pnpm --filter photo-horse-marketing build",
    "build:wasm": "wasm-pack build --target web --out-dir pkg -- --features tiles",
    "build:all": "pnpm run build:wasm && pnpm run build"
  },
  "devDependencies": {
    "convex": "catalog:"
  }
}
